# mareOS hardened npm defaults (seeded into every new user's home via /etc/skel)
#
# Rationale: https://crftd.tech/blog/2026-05-30-notes-on-safer-development/
# These are the lowest-trust tier (project dependencies) and must be treated
# with suspicion. NOTE: dependencies should be installed INSIDE a container, not
# on the host (the host ships no node/npm). This file is the safety net for the
# containers and any toolbox that mounts the home directory.

# Never execute pre/post-install lifecycle scripts. The single most important
# control against install-time malware.
ignore-scripts=true

# Pin exact versions on install; no caret/tilde ranges sneaking in.
save-exact=true

# Refuse packages whose newest matching version is younger than this (seconds).
# 14 days; gives the ecosystem time to catch a freshly published malicious build.
# (Requires npm >= 12 / supported tooling.)
before-age=1209600

# Be loud about audit problems.
audit-level=moderate

# No implicit fetch-and-execute from the registry.
# Use explicit installs + lockfiles; never `npx` untrusted packages.
